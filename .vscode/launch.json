            "program": "${workspaceFolder}/tools/su_tracker.py",
            "console": "integratedTerminal",
            "args": ["-f", "exps/SU-T-ReID.py", "-b", "1", "-d", "1", "--fp16", "--fuse", "-c", "pretrained/Checkpoint.pth.tar", "--expn", "pretrained"]
        },
    ]
